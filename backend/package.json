{
  "name": "rg-erp-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:init": "tsx src/database/init.ts",
    "package": "npx pkg dist/index.js --targets node18-win-x64 --output ../installer/RGWeb.exe --compress GZip --icon ../frontend/src/assets/logos/RioGestionWhite.ico"
  },
  "pkg": {
    "assets": [
      "dist/**/*.js",
      "dist/**/*.js.map"
    ],
    "outputPath": "../installer"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^11.0.1",
    "multer": "^2.1.1",
    "node-forge": "^1.4.0",
    "soap": "^1.8.0",
    "xml2js": "^0.6.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mssql": "^9.1.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.0",
    "@types/node-forge": "^1.3.14",
    "@types/xml2js": "^0.4.14",
    "@yao-pkg/pkg": "^6.14.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
